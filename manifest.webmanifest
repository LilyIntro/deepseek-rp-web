<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <title>Lily RP</title>

  <meta name="theme-color" content="#ffffff" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-title" content="Lily RP" />
  <meta name="apple-mobile-web-app-status-bar-style" content="default" />

  <link rel="manifest" href="./manifest.webmanifest" />
  <link rel="stylesheet" href="./style.css?v=white1" />
</head>

<body>
  <div class="app">
    <header class="topbar">
      <div>
        <h1>Lily RP</h1>
        <p id="subtitle">DeepSeek 角色扮演网页</p>
      </div>
      <div class="top-actions">
        <button id="characterBtn" type="button" class="ghost">角色卡</button>
        <button id="settingsBtn" type="button" class="ghost">设置</button>
      </div>
    </header>

    <main class="layout">
      <aside class="side">
        <section class="panel">
          <h2 id="characterTitle">未设置角色</h2>
          <p id="scenePreview">点击「角色卡」写入角色设定、场景和记忆。</p>
        </section>

        <section class="panel">
          <h3>状态</h3>
          <p id="connectionStatus">未连接</p>
        </section>

        <section class="panel small">
          <h3>建议</h3>
          <p>模型：deepseek-v4-flash</p>
          <p>温度：0.9</p>
          <p>思考模式：关闭</p>
        </section>
      </aside>

      <section class="chat-area">
        <div id="chat" class="chat"></div>

        <form id="composer" class="composer">
          <textarea id="userInput" rows="1" placeholder="输入你的台词、动作或剧情……"></textarea>
          <button id="continueBtn" type="button" class="secondary">续写</button>
          <button id="sendBtn" type="submit">发送</button>
        </form>
      </section>
    </main>
  </div>

  <dialog id="settingsDialog">
    <form class="dialog-card" method="dialog">
      <div class="dialog-head">
        <h2>设置</h2>
        <button id="closeSettings" type="button" class="icon-btn">×</button>
      </div>

      <label>
        Worker 接口地址
        <input id="workerUrl" value="https://deepseek-proxy.marea-deepseek-web.workers.dev/chat" />
      </label>

      <label>
        APP_TOKEN
        <input id="appToken" type="password" placeholder="输入你在 Cloudflare 设置的 APP_TOKEN" />
      </label>

      <label>
        模型
        <select id="modelSelect">
          <option value="deepseek-v4-flash">deepseek-v4-flash</option>
          <option value="deepseek-v4-pro">deepseek-v4-pro</option>
        </select>
      </label>

      <div class="grid">
        <label>
          Temperature
          <input id="temperature" type="number" min="0" max="2" step="0.1" value="0.9" />
        </label>

        <label>
          Max Tokens
          <input id="maxTokens" type="number" min="256" max="4000" step="100" value="2800" />
        </label>
      </div>

      <label class="check">
        <input id="thinkingMode" type="checkbox" />
        开启思考模式
      </label>

      <div class="dialog-actions">
        <button id="clearBtn" type="button" class="danger">清空对话</button>
        <span></span>
        <button id="cancelSettings" type="button" class="secondary">取消</button>
        <button id="saveSettings" type="button">保存</button>
      </div>
    </form>
  </dialog>

  <dialog id="characterDialog">
    <form class="dialog-card wide" method="dialog">
      <div class="dialog-head">
        <h2>角色卡</h2>
        <button id="closeCharacter" type="button" class="icon-btn">×</button>
      </div>

      <div class="grid">
        <label>
          角色名
          <input id="characterName" placeholder="例如：莉莉娅" />
        </label>

        <label>
          你的昵称
          <input id="playerName" placeholder="例如：旅人" />
        </label>
      </div>

      <label>
        角色设定
        <textarea id="characterPrompt" rows="5" placeholder="写角色身份、性格、说话方式、关系、禁忌等。"></textarea>
      </label>

      <label>
        场景设定
        <textarea id="scenarioPrompt" rows="5" placeholder="写当前地点、世界观、开场剧情、当前任务等。"></textarea>
      </label>

      <label>
        长期记忆
        <textarea id="memoryPrompt" rows="4" placeholder="写已经发生的重要事件、关系变化、约定等。"></textarea>
      </label>

      <label>
        回复风格
        <textarea id="stylePrompt" rows="4" placeholder="例如：沉浸式描写；不要代替用户发言；每次回复 2-6 段。"></textarea>
      </label>

      <div class="dialog-actions">
        <button id="exportBtn" type="button" class="secondary">导出存档</button>
        <span></span>
        <button id="cancelCharacter" type="button" class="secondary">取消</button>
        <button id="saveCharacter" type="button">保存角色卡</button>
      </div>
    </form>
  </dialog>

  <script src="./app.js?v=white1"></script>
</body>
</html>
